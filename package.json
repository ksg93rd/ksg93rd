{
  "name": "emoji-oracle-game",
  "version": "1.0.0",
  "description": "A lightweight browser game that teaches players to translate between emojis, words, and spoken answers.",
  "type": "module",
  "scripts": {
    "start": "python3 -m http.server 4173 --bind 127.0.0.1",
    "preview": "python3 -m http.server 4173 --bind 127.0.0.1",
    "launch:local": "python3 -m http.server 4173 --bind 0.0.0.0",
    "test": "node --test tests/*.test.js",
    "test:unit": "node --test tests/gameLogic.test.js tests/challenges.test.js",
    "test:smoke": "node --test tests/staticApp.test.js",
    "test:all": "npm run test:unit && npm run test:smoke"
  },
  "keywords": [
    "emoji",
    "game",
    "education",
    "speech-recognition",
    "browser-game"
  ],
  "author": "Ksg93rd",
  "license": "MIT"
}
